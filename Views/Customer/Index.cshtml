@model List<Loan_Procedure.DTOs.Customer.CustomerResponseDto>

@{
    ViewData["Title"] = "Customers List";
    int currentPage = ViewBag.CurrentPage ?? 1;
    int pageSize = ViewBag.PageSize ?? 10;
    int totalRecords = ViewBag.TotalRecords ?? 0;
    int totalPages = (int)Math.Ceiling((double)totalRecords / pageSize);
    int sl = (currentPage - 1) * pageSize + 1;
}

<h2>Customers</h2>
<div class="row mb-3 align-items-end">
    <div class="col-md-3">
        <form method="get">
            <label class="form-label">Rows per page</label>
            <select name="pageSize" class="form-select" asp-items="ViewBag.PageSizes" onchange="this.form.submit()"></select>
        </form>
    </div>

    <div class="col-md-9 d-flex justify-content-end">
        <a asp-action="Create" class="btn btn-primary">Add Customer</a>
    </div>
</div>
@if (Model == null || !Model.Any())
{
    <div class="alert alert-warning">
        Customer not found
    </div>
}
else
{
    <table class="table table-striped table-bordered table-responsive">
        <thead class="table-dark">
            <tr>
                <th class="text-center">SL</th>
                <th class="text-center">Name</th>
                <th class="text-center">NID</th>
                <th class="text-center">Mobile</th>
                <th class="text-center">Monthly Income</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var customer in Model)
            {
                <tr>
                    <td class="text-center">@(sl++)</td>
                    <td>@customer.Name</td>
                    <td>@customer.NID</td>
                    <td>@customer.Mobile</td>
                    <td>@customer.Income.ToString("C")</td>
                    <td class="text-center">
                        <a asp-action="Edit" asp-route-id="@customer.CustomerId" class="btn btn-sm btn-warning">Update</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <!-- Pagination -->
    <nav>
        <ul class="pagination justify-content-center mt-3">
            <!-- Previous button -->
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-pageSize="@pageSize">Previous</a>
            </li>

            <!-- Page numbers -->
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(currentPage == i ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-pageSize="@pageSize">@i</a>
                </li>
            }

            <!-- Next button -->
            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-pageSize="@pageSize">Next</a>
            </li>
        </ul>
    </nav>
}
