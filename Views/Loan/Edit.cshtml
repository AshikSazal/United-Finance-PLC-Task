@model Loan_Procedure.Models.Loan

@{
    ViewData["Title"] = "Update Loan";
}

@if (!ViewData.ModelState.IsValid)
{
    var firstError = ViewData.ModelState.Values.SelectMany(v => v.Errors).FirstOrDefault()?.ErrorMessage ?? "Please fix the errors!";

    <div class="position-fixed top-0 end-0 p-3" style="z-index: 1080;">
        <div class="toast align-items-center text-bg-danger border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body">
                    @firstError
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>
}

<h2>Edit Loan</h2>

@if (Model == null)
{
    <h1 class="text-danger text-center">Loan Not Found</h1>
    <div class="text-center mt-3">
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </div>
    return;
}

@if(Model.Status > 1)
{
    <h1 class="text-danger text-center">Loan Already Approved/Rejected</h1>
    <div class="text-center mt-3">
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </div>
    return;
}

<form asp-action="Edit" method="post" class="row g-3">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="LoanId" />
    <div class="col-md-6">
        <label asp-for="CustomerId" class="form-label">Customer</label>
        <select asp-for="CustomerId" class="form-select" asp-items="ViewBag.Customers">
            <option value="">-- Select Customer --</option>
        </select>
        <span asp-validation-for="CustomerId" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Amount" class="form-label"></label>
        <input asp-for="Amount" class="form-control" />
        <span asp-validation-for="Amount" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="LoanType" class="form-label">Loan Type</label>
        <input asp-for="LoanType" class="form-control" />
        <span asp-validation-for="LoanType" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Tenor" class="form-label"></label>
        <input asp-for="Tenor" class="form-control" />
        <span asp-validation-for="Tenor" class="text-danger"></span>
    </div>

    <div class="col-12">
        <label asp-for="Purpose" class="form-label"></label>
        <textarea asp-for="Purpose" class="form-control"></textarea>
        <span asp-validation-for="Purpose" class="text-danger"></span>
    </div>

    <div class="col-12 mt-2">
        <button type="submit" @(ViewData.ModelState.IsValid ? "" : "disabled") class="btn btn-success">Update</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Initialize Bootstrap toasts
        var toastElList = [].slice.call(document.querySelectorAll('.toast'))
        var toastList = toastElList.map(function (toastEl) {
            return new bootstrap.Toast(toastEl)
        })
        toastList.forEach(toast => toast.show())
    </script>
}
