@model List<Loan_Procedure.DTOs.Loan.LoanResponseDto>
@using Loan_Procedure.Utils.Constants;

@{
    ViewData["Title"] = "Loans";
}

<h2>Loan List</h2>

<form method="get" class="row g-3 mb-3 align-items-end">
    <div class="col-md-6">
        <label class="form-label">Customer</label>
        <select name="customerId" class="form-select" asp-items="ViewBag.Customers">
            <option value="">-- Select Customer --</option>
        </select>
    </div>

    <div class="col-md-4">
        <label class="form-label">Status</label>
        <select name="status" class="form-select" asp-items="ViewBag.Statuses"></select>
    </div>

    <div class="col-md-2">
        <button type="submit" class="btn btn-primary">Filter</button>
        <a asp-action="Create" class="btn btn-success">Add Loan</a>
    </div>
</form>


@if (Model == null || !Model.Any())
{
    <div class="alert alert-warning">
        No loans found.
    </div>
}
else
{
    <table class="table table-striped table-bordered table-responsive">
        <thead class="table-dark">
            <tr>
                <th class="text-center">SL</th>
                <th class="text-center">Customer</th>
                <th class="text-center">Amount</th>
                <th class="text-center">Loan Type</th>
                <th class="text-center">Tenor (Months)</th>
                <th class="text-center">Status</th>
                <th class="text-center">Created Date</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @{
                int sl = 1;
            }
            @foreach (var loan in Model)
            {
                <tr>
                    <td class="text-center">@(sl++)</td>
                    <td>@loan.CustomerName</td>
                    <td>@loan.Amount.ToString("C")</td>
                    <td>@loan.LoanType</td>
                    <td>@loan.Tenor</td>
                    <td>@loan.StatusText</td>
                    <td>@loan.CreatedDate.ToString("yyyy-MM-dd")</td>
                    <td class="text-center">
                        @if (loan.Status == (byte)LoanStatus.Draft || loan.Status == (byte)LoanStatus.Submitted)
                        {
                            <a asp-action="Edit" asp-route-id="@loan.LoanId" class="btn btn-sm btn-warning">Update</a>
                        }
                        @if (loan.Status == (byte)LoanStatus.Draft)
                        {
                            <a asp-action="Submit" asp-route-id="@loan.LoanId" class="btn btn-sm btn-primary">Submit</a>
                        }
                        @if (loan.Status == (byte)LoanStatus.Submitted)
                        {
                            <a asp-action="Approve" asp-route-id="@loan.LoanId" class="btn btn-sm btn-success">Approve</a>
                            <a asp-action="Reject" asp-route-id="@loan.LoanId" class="btn btn-sm btn-danger">Reject</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
